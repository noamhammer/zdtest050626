zendesk.ticket_field Preferred_Game_multiselect@su {
  type = "multiselect"
  raw_title = "Preferred Game"
  raw_description = "What is your preferred game?"
  active = true
  required = false
  collapsed_for_agents = false
  raw_title_in_portal = "Preferred Game"
  visible_in_portal = true
  editable_in_portal = true
  required_in_portal = true
  agent_can_edit = true
  removable = true
  agent_description = "What is your preferred game?"
  raw_agent_description = "What is your preferred game?"
  custom_field_options = [
    zendesk.ticket_field__custom_field_options.instance.Preferred_Game_multiselect__chess@suuu,
    zendesk.ticket_field__custom_field_options.instance.Preferred_Game_multiselect__checkers@suuu,
    zendesk.ticket_field__custom_field_options.instance.Preferred_Game_multiselect__domino@suuu,
    zendesk.ticket_field__custom_field_options.instance.Preferred_Game_multiselect__go@suuu,
    zendesk.ticket_field__custom_field_options.instance.Preferred_Game_multiselect__fortnite@suuu,
  ]
  default_custom_field_option = zendesk.ticket_field__custom_field_options.instance.Preferred_Game_multiselect__fortnite@suuu
  _alias = "Preferred Game"
}
