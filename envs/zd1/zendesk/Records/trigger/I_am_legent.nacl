zendesk.trigger I_am_legent@s {
  title = "I am legent"
  active = true
  default = false
  actions = [
    {
      field = "notification_user"
      value = [
        "requester_and_ccs",
        "hola",
        "hola",
      ]
    },
  ]
  conditions = {
    all = [
      {
        field = "update_type"
        operator = "is"
        value = "Create"
      },
    ]
  }
  raw_title = "I am legent"
  category_id = zendesk.trigger_category.instance.Notifications
  _alias = "I am legent"
}
