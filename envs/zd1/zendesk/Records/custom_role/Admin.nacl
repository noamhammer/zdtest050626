zendesk.custom_role Admin {
  name = "Admin"
  description = "Can manage all settings, except billing"
  configuration = {
    chat_access = true
    end_user_list_access = "full"
    forum_access_restricted_content = false
    light_agent = false
    manage_business_rules = true
    manage_dynamic_content = true
    manage_extensions_and_channels = true
    manage_facebook = true
    moderate_forums = false
    side_conversation_create = true
    ticket_access = "all"
    ticket_comment_access = "public"
    ticket_deletion = true
    ticket_tag_editing = true
    twitter_search_access = false
    view_deleted_tickets = true
    voice_access = true
    group_access = true
    organization_editing = true
    organization_notes_editing = true
    assign_tickets_to_any_group = true
    end_user_profile_access = "full"
    explore_access = "full"
    forum_access = "full"
    macro_access = "full"
    report_access = "full"
    ticket_editing = true
    ticket_merge = true
    user_view_access = "full"
    view_access = "full"
    voice_dashboard_access = true
    assign_agent_statuses = true
    manage_api_credentials = true
    manage_automations = true
    manage_contextual_workspaces = true
    manage_groups = true
    manage_group_memberships = true
    manage_malicious_attachments = true
    manage_organizations = true
    manage_organization_fields = true
    manage_skills = true
    manage_slas = true
    manage_support_apps = true
    manage_suspended_tickets = true
    manage_ticket_fields = true
    manage_ticket_forms = true
    manage_ticket_settings = true
    manage_triggers = true
    manage_user_fields = true
    manage_user_own_contacts = true
    manage_user_own_forwarding_numbers = true
    manage_user_own_photo = true
    ticket_redaction = true
    update_api_settings = true
    update_user_own_alias = true
    update_user_own_name = true
    update_user_own_signature = true
    manage_macro_content_suggestions = true
    modify_closed_tickets = true
    read_macro_content_suggestions = true
    view_reduced_count = false
    view_filter_tickets = true
    export_views = true
    manage_roles = "all"
    manage_deletion_schedules = "all"
    explore_reports = {
      ticket_access = "all"
      groups_ticket_access = "all"
      brands_ticket_access = "all"
    }
    manage_team_members = "all"
    manage_approval_requests = true
    it_asset_management_access = "full"
    manage_it_asset_configuration = true
    assign_tickets_to_any_brand = true
    manage_ip_bans = "all"
    view_audit_logs = true
    view_access_logs = true
    execute_it_asset_management_actions = true
    capacity_rules_access = "all"
    custom_objects = {
      a = {
        scopes = [
          "read",
          "create",
          "update",
          "delete",
        ]
      }
      stagingtest = {
        scopes = [
          "read",
          "create",
          "update",
          "delete",
        ]
      }
      stagingtest1 = {
        scopes = [
          "read",
          "create",
          "update",
          "delete",
        ]
      }
    }
  }
  _alias = "Admin"
}
