zendesk.view All_unsolved_tickets@s {
  active = true
  default = false
  execution = {
    group_by = "assignee"
    group_order = "asc"
    sort_by = "nice_id"
    sort_order = "desc"
    group = {
      id = "assignee"
      title = "Assignee"
      filterable = true
      sortable = true
      order = "asc"
    }
    sort = {
      id = "ticket_id"
      title = "ID"
      filterable = true
      sortable = true
      order = "desc"
    }
    columns = [
      {
        id = "custom_status_id"
        title = "Ticket status"
        filterable = true
        sortable = false
      },
      {
        id = "subject"
        title = "Subject"
        filterable = true
        sortable = true
      },
      {
        id = "requester"
        title = "Requester"
        filterable = true
        sortable = true
      },
      {
        id = "created"
        title = "Requested"
        filterable = false
        sortable = true
      },
      {
        id = "priority"
        title = "Priority"
        filterable = true
        sortable = true
      },
      {
        id = "updated"
        title = "Updated"
        filterable = true
        sortable = true
      },
    ]
    fields = [
      {
        id = "custom_status_id"
        title = "Ticket status"
        filterable = true
        sortable = false
      },
      {
        id = "subject"
        title = "Subject"
        filterable = true
        sortable = true
      },
      {
        id = "requester"
        title = "Requester"
        filterable = true
        sortable = true
      },
      {
        id = "created"
        title = "Requested"
        filterable = false
        sortable = true
      },
      {
        id = "priority"
        title = "Priority"
        filterable = true
        sortable = true
      },
      {
        id = "updated"
        title = "Updated"
        filterable = true
        sortable = true
      },
    ]
  }
  conditions = {
    all = [
      {
        field = "status"
        operator = "less_than"
        value = "solved"
      },
      {
        field = "support_type"
        operator = "is"
        value = "0"
      },
    ]
  }
  restriction = {
    type = "User"
    id = "zendesk-adapter@salto.io"
  }
  raw_title = "All unsolved tickets"
  _alias = "All unsolved tickets"
}
